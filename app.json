{
  "expo": {
    "name": "TB Masdar Utama Mobile",
    "slug": "tb-masdarutama-mobile",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6e4aad91-e3dc-44f4-97f3-0f332f02dd6e",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/logomasdarutama.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F0F23"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logomasdarutama.png",
        "backgroundColor": "#0F0F23"
      },
      "package": "com.tbmasdarutama.mobile",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      "expo-audio",
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "6e4aad91-e3dc-44f4-97f3-0f332f02dd6e"
      }
    }
  }
}
